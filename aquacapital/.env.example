# Copernicus Data Space Ecosystem credentials
# Register free at https://dataspace.copernicus.eu
CDSE_USER=your_email@example.com
CDSE_PASSWORD=your_password

# Anthropic API key for AI explanation layer
# Get at https://console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-...

# Romania World Bank governance score (default 0.3, range -2.5 to +2.5)
ROMANIA_GOVERNANCE_SCORE=0.3

# Default country ISO code
DEFAULT_COUNTRY=RO
